# Qdrant
QDRANT_URL=http://qdrant:6333

# API Keys
GOOGLE_API_KEY=xxx                          # Gemini embeddings
ANTHROPIC_API_KEY=sk-ant-xxx                # Claude Haiku metadata extraction
FIREFLIES_API_KEY=xxx                       # Fireflies transcripts (agent tool)

# Auth
CAPTURE_SECRET=your-random-secret           # Bearer token for POST /capture

# Google Drive — Service Account (reads People/Projects for metadata context)
GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json
GOOGLE_DRIVE_FOLDER_ID=xxx                  # Root folder ID for Obsidian vault

# Google Drive — OAuth2 (writes exports + agent tools: Gmail, Calendar, YouTube)
GOOGLE_DRIVE_CLIENT_ID=xxx
GOOGLE_DRIVE_CLIENT_SECRET=xxx
GOOGLE_DRIVE_REFRESH_TOKEN=xxx              # Run scripts/get-drive-token.js to generate

# Server
PORT=3000
